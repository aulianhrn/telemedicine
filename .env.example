PORT=3000
JWT_SECRET=ganti_dengan_secret_yang_panjang

# Cloud SQL MySQL.
# Local development biasanya tetap pakai TCP:
# - Public IP Cloud SQL di DB_HOST, atau
# - 127.0.0.1 kalau Cloud SQL Auth Proxy berjalan di mode TCP.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=telemed
DB_PASSWORD=ganti_password_database
DB_NAME=telemedicine_posyandu
DB_SSL=false

# Default untuk Cloud Run: pakai Cloud SQL Unix socket.
# Kalau DB_SOCKET_PATH diisi, DB_HOST dan DB_PORT akan diabaikan oleh backend.
# Format: /cloudsql/project-id:region:instance-id
# Contoh Cloud Run: DB_SOCKET_PATH=/cloudsql/PROJECT_ID:REGION:INSTANCE_ID
DB_SOCKET_PATH=

# Google Cloud Storage untuk avatar.
# Di Cloud Run, credential diambil otomatis dari service account runtime.
# Pastikan service account runtime punya role Storage Object Admin di bucket ini.
GCS_BUCKET_NAME=telemedicine-posyandu-avatar

# Firebase Admin / Firestore.
# Local development bisa memakai file backend/serviceAccountKey.json.
# Cloud Run lebih aman memakai env FIREBASE_SERVICE_ACCOUNT_JSON dari Secret Manager.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Worker notifikasi.
# Jika diisi, endpoint POST /api/notifications/process-events bisa dipanggil worker
# dengan header x-worker-secret atau x-notification-worker-secret.
NOTIFICATION_WORKER_SECRET=

# Catatan skenario hybrid SQL + NoSQL untuk mobile:
# SQL menyimpan data utama pemeriksaan/imunisasi.
# Firestore dipakai mobile untuk catatan fleksibel dan data pendukung.
SQL_EXAMINATIONS_TABLE=examinations
SQL_IMMUNIZATIONS_TABLE=immunizations
NOSQL_MEDICAL_RECORDS_COLLECTION=medical_records
NOSQL_GROWTH_CHARTS_COLLECTION=growth_charts
NOSQL_DYNAMIC_EXAMINATIONS_COLLECTION=dynamic_examinations
