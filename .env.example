PORT=3000
JWT_SECRET=ganti_dengan_secret_yang_panjang

# Cloud SQL MySQL connection.
# Isi DB_HOST dengan public IP Cloud SQL, private IP, atau Cloud SQL proxy host.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=adminposyandu
DB_PASSWORD=pass123
DB_NAME=telemedicine_posyandu
DB_SSL=false

# Skenario hybrid SQL + NoSQL:
# SQL menyimpan examinations/immunizations, Flutter menyimpan catatan fleksibel ke Firestore.
SQL_EXAMINATIONS_TABLE=examinations
SQL_IMMUNIZATIONS_TABLE=immunizations
NOSQL_MEDICAL_RECORDS_COLLECTION=medical_records
NOSQL_GROWTH_CHARTS_COLLECTION=growth_charts
NOSQL_DYNAMIC_EXAMINATIONS_COLLECTION=dynamic_examinations

# Opsional untuk Cloud Run/App Engine dengan Cloud SQL Unix socket:
# DB_SOCKET_PATH=/cloudsql/project-id:region:instance-id
